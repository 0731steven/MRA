# ============================================================
# Market Research Assistant — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- App ---
APP_ENV=development                    # development | production
APP_HOST=0.0.0.0
APP_PORT=8101
SECRET_KEY=change-me-to-a-random-string

# --- Database ---
# development: aiosqlite (auto, no config needed)
# production:  async PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./research.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/research

# --- Company knowledge base (L0/L1/L2) ---
COMPANY_LIB_PATH=./company_lib
MRA_KB_CHAR_BUDGET=120000

# --- Market Engine (read-only) ---
ME_API_MODE=mock                       # mock | real
ME_API_BASE_URL=http://127.0.0.1:8002
ME_API_KEY=

# Legacy compatibility only; main MRA pipeline does not read this variable.
WILSON_LIB_PATH=./company_lib
PYTHON_BIN=python3.13
MINERU_API_TOKEN=           # MinerU cloud API token (jwt); set this to use cloud conversion instead of local MinerU CLI

# --- Script path overrides (defaults relative to WILSON_LIB_PATH/tools/scripts/) ---
# IEEE_PDF_SRC=~/Downloads/ieee_papers
# PATENT_PDF_SRC=~/Downloads/patents
# WEB_DOWNLOAD_DIR=~/Downloads/web_articles

# --- Staging (remote docs temp area, relative to WILSON_LIB_PATH) ---
# STAGING_DIR=staging
# Days a PendingDocument may sit unreviewed before auto-expiry (staging file deleted).
PENDING_DOC_EXPIRE_DAYS=30

# --- Extra search paths for check_report.py during staging ---
# EXTRA_SEARCH_PATHS=staging/task_1/ieee,staging/task_1/patent

# --- DeepSeek through OpenAI SDK ---
DEEPSEEK_API_KEY=replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
# Offline/CI only. Never enable in production.
DEEPSEEK_MOCK=false

# --- Feishu Bot ---
FEISHU_ENABLED=false
FEISHU_BOT_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# --- Feishu OAuth (Web login) ---
FEISHU_REDIRECT_URI=http://localhost:8002/api/auth/feishu/callback

# --- Admin whitelist (comma-separated feishu user_ids) ---
ADMIN_FEISHU_IDS=

# --- Tier defaults ---
DEFAULT_TIER=normal                    # quick | normal | deep

# --- Chrome Browser Pool ---
CDP_PORT_BASE=9222          # 第一个 Chrome 实例的 CDP 端口，后续实例依次 +1
CDP_POOL_SIZE=1             # Chrome 实例数量（1=单实例，多人并发时可调高）
# CHROME_BIN=/usr/bin/google-chrome                   # Chrome 可执行路径
