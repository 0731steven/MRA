# Probability & Mathematical Statistics Teaching Assistant

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8101
SECRET_KEY=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:5173

# Development-only one-click teacher login
DEV_LOGIN_ENABLED=false
DEV_LOGIN_USER_ID=local-teacher
DEV_LOGIN_NAME=本地教师
DEV_LOGIN_ROLE=teacher

DATABASE_URL=sqlite+aiosqlite:///./teaching_assistant.db
QUESTION_BANK_PATH=./data/probability_questions.jsonl

# Docker Compose / PostgreSQL (replace the password before startup)
POSTGRES_DB=mra
POSTGRES_USER=mra
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Optional: create the first teacher once when the database is empty
BOOTSTRAP_TEACHER_USERNAME=
BOOTSTRAP_TEACHER_PASSWORD=
BOOTSTRAP_TEACHER_NAME=初始教师

# Required only when allowing teachers to self-register
TEACHER_REGISTRATION_CODE=

DEEPSEEK_API_KEY=replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_MOCK=false
